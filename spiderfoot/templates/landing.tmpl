<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BotStop — Know What Attackers See About Your Business</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="${docroot}/static/img/botstop-icon.svg">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #000; color: #e2e8f0; line-height: 1.6; }

    /* Nav */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(5,156,215,0.15); padding: 0 40px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
    .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-brand img { height: 28px; }
    .nav-links { display: flex; align-items: center; gap: 24px; }
    .nav-links a { color: #94a3b8; text-decoration: none; font-size: 14px; transition: color 0.15s; }
    .nav-links a:hover { color: #e2e8f0; }
    .nav-cta { background: #059CD7; color: #fff !important; padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px !important; }
    .nav-cta:hover { background: #048ab8 !important; color: #fff !important; }

    /* Hero */
    .hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 120px 24px 80px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 30%, rgba(5,156,215,0.18) 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, rgba(231,76,60,0.08) 0%, transparent 50%); pointer-events: none; }
    .hero-inner { position: relative; max-width: 760px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(5,156,215,0.12); border: 1px solid rgba(5,156,215,0.3); color: #38bdf8; font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; margin-bottom: 28px; text-transform: uppercase; letter-spacing: 0.5px; }
    .hero-badge::before { content: '●'; color: #059CD7; font-size: 8px; }
    .hero h1 { font-size: clamp(36px, 6vw, 64px); font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 20px; letter-spacing: -1px; }
    .hero h1 span { color: #059CD7; }
    .hero-sub { font-size: clamp(16px, 2.5vw, 20px); color: #94a3b8; max-width: 560px; margin: 0 auto 40px; line-height: 1.6; }
    .hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .btn-primary-lg { background: #059CD7; color: #fff; padding: 14px 32px; border-radius: 8px; font-size: 16px; font-weight: 700; text-decoration: none; transition: background 0.15s, transform 0.1s; display: inline-flex; align-items: center; gap: 8px; }
    .btn-primary-lg:hover { background: #048ab8; transform: translateY(-1px); color: #fff; }
    .btn-ghost-lg { background: rgba(255,255,255,0.05); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.12); padding: 14px 32px; border-radius: 8px; font-size: 16px; font-weight: 600; text-decoration: none; transition: background 0.15s; }
    .btn-ghost-lg:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .hero-note { margin-top: 20px; font-size: 13px; color: #475569; }

    /* Stats bar */
    .stats-bar { background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 28px 40px; display: flex; justify-content: center; gap: 64px; flex-wrap: wrap; }
    .stat { text-align: center; }
    .stat-num { font-size: 28px; font-weight: 800; color: #059CD7; line-height: 1; }
    .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Sections */
    section { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
    .section-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #059CD7; margin-bottom: 12px; }
    .section-title { font-size: clamp(26px, 4vw, 40px); font-weight: 800; color: #fff; line-height: 1.2; margin-bottom: 16px; letter-spacing: -0.5px; }
    .section-sub { font-size: 17px; color: #64748b; max-width: 540px; line-height: 1.65; }
    .section-centered { text-align: center; }
    .section-centered .section-sub { margin: 0 auto 0; }

    /* Problem */
    .problem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-top: 48px; }
    .problem-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 24px; transition: box-shadow 0.3s, transform 0.3s; }
    .problem-card .icon { width: 44px; height: 44px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #f87171; margin-bottom: 14px; }
    .problem-card h3 { font-size: 15px; font-weight: 700; color: #e2e8f0; margin-bottom: 8px; }
    .problem-card p { font-size: 13.5px; color: #64748b; line-height: 1.6; }
    .problem-card.danger { border-color: rgba(239,68,68,0.25); background: rgba(239,68,68,0.04); box-shadow: 0 0 32px rgba(239,68,68,0.12), 0 4px 24px rgba(0,0,0,0.4); }
    .problem-card.danger:hover { box-shadow: 0 0 48px rgba(239,68,68,0.22), 0 8px 32px rgba(0,0,0,0.5); transform: translateY(-4px) scale(1.02); }

    /* Scroll animations — slide from left/right/up */
    .slide-left  { opacity: 0; transform: translateX(-72px); }
    .slide-right { opacity: 0; transform: translateX( 72px); }
    .fade-up     { opacity: 0; transform: translateY( 36px); }
    .slide-left, .slide-right, .fade-up {
      transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1);
    }
    .slide-left.visible, .slide-right.visible, .fade-up.visible {
      opacity: 1; transform: translate(0,0);
    }

    /* How it works */
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0; margin-top: 56px; position: relative; }
    .step { text-align: center; padding: 0 32px; position: relative; }
    .step + .step::before { content: '→'; position: absolute; left: -8px; top: 28px; color: #1e3a5f; font-size: 24px; }
    .step-num { width: 56px; height: 56px; background: rgba(5,156,215,0.12); border: 2px solid rgba(5,156,215,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 800; color: #059CD7; margin: 0 auto 16px; }
    .step h3 { font-size: 16px; font-weight: 700; color: #e2e8f0; margin-bottom: 8px; }
    .step p { font-size: 13.5px; color: #64748b; line-height: 1.6; }

    /* What we find */
    .finds-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 48px; }
    @media (max-width: 900px) { .finds-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .finds-grid { grid-template-columns: 1fr; } }
    .find-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 18px 20px; display: flex; align-items: flex-start; gap: 14px; transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease; }
    .find-item:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 24px rgba(5,156,215,0.1); border-color: rgba(5,156,215,0.3); }
    .find-icon { flex-shrink: 0; width: 36px; height: 36px; background: rgba(5,156,215,0.1); border: 1px solid rgba(5,156,215,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #059CD7; }
    .find-text strong { display: block; font-size: 13.5px; color: #e2e8f0; font-weight: 600; margin-bottom: 3px; }
    .find-text span { font-size: 12px; color: #475569; line-height: 1.5; }

    /* Pricing */
    .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 56px; }
    .pricing-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 32px; position: relative; transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease; }
    .pricing-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 32px rgba(5,156,215,0.12); border-color: rgba(5,156,215,0.3); }
    .pricing-card.featured:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 40px rgba(5,156,215,0.22); }
    .pricing-card.featured { background: rgba(5,156,215,0.07); border-color: rgba(5,156,215,0.35); }
    .pricing-card .badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #059CD7; color: #fff; font-size: 11px; font-weight: 700; padding: 4px 14px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
    .plan-name { font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: #64748b; margin-bottom: 8px; }
    .plan-price { font-size: 40px; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 4px; }
    .plan-price sup { font-size: 20px; font-weight: 600; vertical-align: top; margin-top: 6px; color: #94a3b8; }
    .plan-price .per { font-size: 14px; font-weight: 400; color: #64748b; }
    .plan-desc { font-size: 13px; color: #64748b; margin: 12px 0 24px; line-height: 1.5; }
    .plan-features { list-style: none; margin-bottom: 28px; }
    .plan-features li { font-size: 13.5px; color: #94a3b8; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; gap: 8px; }
    .plan-features li:last-child { border-bottom: none; }
    .plan-features li::before { content: '✓'; color: #059CD7; font-weight: 700; flex-shrink: 0; }
    .plan-btn { display: block; text-align: center; padding: 11px; border-radius: 8px; font-size: 14px; font-weight: 700; text-decoration: none; transition: all 0.15s; }
    .plan-btn-primary { background: #059CD7; color: #fff; }
    .plan-btn-primary:hover { background: #048ab8; color: #fff; }
    .plan-btn-ghost { background: transparent; color: #94a3b8; border: 1px solid rgba(255,255,255,0.1); }
    .plan-btn-ghost:hover { border-color: rgba(255,255,255,0.25); color: #e2e8f0; }

    /* CTA section */
    .cta-section { text-align: center; padding: 80px 24px; }
    .cta-box { background: linear-gradient(135deg, rgba(5,156,215,0.1) 0%, rgba(5,156,215,0.04) 100%); border: 1px solid rgba(5,156,215,0.25); border-radius: 20px; padding: 64px 48px; max-width: 700px; margin: 0 auto; }
    .cta-box h2 { font-size: clamp(26px, 4vw, 40px); font-weight: 800; color: #fff; margin-bottom: 16px; }
    .cta-box p { font-size: 17px; color: #64748b; margin-bottom: 36px; }

    /* Footer */
    footer { background: rgba(0,0,0,0.6); border-top: 1px solid rgba(255,255,255,0.05); padding: 32px 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
    footer .left { font-size: 13px; color: #475569; }
    footer .right { display: flex; gap: 20px; }
    footer .right a { font-size: 13px; color: #475569; text-decoration: none; }
    footer .right a:hover { color: #94a3b8; }

    @media (max-width: 640px) {
      .nav { padding: 0 20px; }
      .stats-bar { gap: 32px; }
      .step + .step::before { display: none; }
      footer { flex-direction: column; text-align: center; }
    }
  </style>
</head>
