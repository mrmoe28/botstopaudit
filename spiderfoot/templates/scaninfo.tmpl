                    }, 
                    format: function(s) { 
                        return s.toLowerCase().replace(/high/,3).replace(/medium/,2).replace(/low/,1).replace(/info/,0); 
                    }, 
                    type: 'numeric' 
                });
                $("#scansummary-content").tablesorter({ headers: { 1: { sorter: 'criticality' } } });
                sf.updateTooltips();
            });
        }

