<%include file="HEADER.tmpl"/>
<div class="container" style="max-width:560px;margin:40px auto;padding:0 16px;">
  <h2 style="margin-bottom:24px;">Profile</h2>
  <div class="panel panel-default">
    <div class="panel-body" style="padding:32px;">

      <div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
        % if user.get('avatar'):
        <img src="${user['avatar']}" width="72" height="72" style="border-radius:50%;object-fit:cover;" referrerpolicy="no-referrer">
        % else:
        <span style="display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border-radius:50%;background:#059CD7;color:#fff;font-size:28px;font-weight:700;">
          ${(user.get('name') or user.get('email','?'))[0].upper()}
        </span>
        % endif
        <div>
          <div style="font-size:1.25rem;font-weight:600;">${user.get('name', '')}</div>
          <div style="color:#888;font-size:0.9rem;">${user.get('email', '')}</div>
        </div>
      </div>

      <table class="table">
        <tr>
          <td style="color:#888;width:140px;">Name</td>
          <td>${user.get('name', '—')}</td>
        </tr>
        <tr>
          <td style="color:#888;">Email</td>
          <td>${user.get('email', '—')}</td>
        </tr>
        <tr>
          <td style="color:#888;">Role</td>
          <td>${(user.get('role') or 'user').title()}</td>
        </tr>
        <tr>
          <td style="color:#888;">Plan</td>
          <td>
            <% _plan = db_user.get('plan', 'free') %>
            % if _plan == 'professional':
            <span class="label label-info">Professional</span>
            % elif _plan == 'agency':
            <span class="label label-primary">Agency</span>
            % else:
            <span class="label label-default">Free</span>
            % endif
          </td>
        </tr>
        <tr>
          <td style="color:#888;">Scans Run</td>
          <td>${db_user.get('scan_count', 0)}</td>
        </tr>
      </table>

      <div style="margin-top:16px;display:flex;gap:12px;">
        <a href="${docroot}/billing" class="btn btn-primary">Manage Billing</a>
        <a href="${docroot}/logout" class="btn btn-default">Sign Out</a>
      </div>
    </div>
  </div>
</div>
<%include file="FOOTER.tmpl"/>
